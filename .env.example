# PDF Knowledge Search - Environment Configuration Example
# Copy this to .env and modify values as needed

# ===== BACKEND CONFIGURATION =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DEBUG=false

# ===== OLLAMA CONFIGURATION =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi
# Available models: phi, orca-mini, neural-chat, mistral

# ===== EMBEDDING CONFIGURATION =====
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DB_PATH=./data/chroma_db

# ===== SEARCH CONFIGURATION =====
SEARCH_TOP_K=2
SEARCH_TEMPERATURE=0.7
SEARCH_MAX_TOKENS=30

# ===== FRONTEND CONFIGURATION =====
REACT_APP_API_URL=http://localhost:8000
REACT_APP_TIMEOUT=180000

# ===== FILE PATHS =====
DOCUMENTS_DIR=./documents
DATA_DIR=./data

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ===== SECURITY (Production Only) =====
# CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]
# API_KEY=your-secret-key-here
# JWT_SECRET=your-jwt-secret

# ===== NOTES =====
# - Never commit actual .env file to git
# - Use .env.example for documentation
# - For production, add proper authentication
# - Adjust timeouts based on your system performance
EMBEDDING_MODEL=all-MiniLM-L6-v2
